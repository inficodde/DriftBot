<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="driftbot">
    <pose>0 0 0.05 0 0 0</pose>
    <link name="chassis">
      <pose>0 0 0.05 0 0 0</pose>
      <inertial>
        <mass>4.5</mass> 
        <pose>0 0 -0.02 0 0 0</pose> 
        <inertia><ixx>0.014</ixx><iyy>0.062</iyy><izz>0.070</izz></inertia>
      </inertial>
      <visual name="visual">
        <pose>0 0 -0.05 1.57 0 1.57</pose>
        <geometry><mesh><uri>model://prius_hybrid/meshes/Audi_R8_Spyder.obj</uri><scale>0.1 0.1 0.1</scale></mesh></geometry>
      </visual>
      <collision name="collision">
        <geometry><box><size>0.45 0.18 0.08</size></box></geometry>
      </collision>
    </link>

    <link name="front_left_wheel">
      <pose>0.13 0.10 0.0325 -1.57 0 0</pose>
      <inertial> <mass>0.5</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.0325</radius><length>0.026</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>
    <link name="front_right_wheel">
      <pose>0.13 -0.10 0.0325 -1.57 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.0325</radius><length>0.026</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>

    <link name="rear_left_wheel">
      <pose>-0.13 0.10 0.0325 -1.57 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.0325</radius><length>0.026</length></cylinder></geometry>
        <surface><friction><ode><mu>0.25</mu><mu2>0.25</mu2></ode></friction></surface>
      </collision>
    </link>
    <link name="rear_right_wheel">
      <pose>-0.13 -0.10 0.0325 -1.57 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia>
      </inertial>
      <collision name="collision">
        <geometry><cylinder><radius>0.0325</radius><length>0.026</length></cylinder></geometry>
        <surface><friction><ode><mu>0.25</mu><mu2>0.25</mu2></ode></friction></surface>
      </collision>
    </link>

    <link name="front_left_knuckle"><pose>0.13 0.10 0.0325 0 0 0</pose><inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial></link>
    <link name="front_right_knuckle"><pose>0.13 -0.10 0.0325 0 0 0</pose><inertial><mass>0.01</mass><inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz></inertia></inertial></link>
    
    <joint type="revolute" name="front_left_steer_joint"><child>front_left_knuckle</child><parent>chassis</parent><axis><xyz>0 0 1</xyz><limit><lower>-0.8</lower><upper>0.8</upper></limit></axis></joint>
    <joint type="revolute" name="front_right_steer_joint"><child>front_right_knuckle</child><parent>chassis</parent><axis><xyz>0 0 1</xyz><limit><lower>-0.8</lower><upper>0.8</upper></limit></axis></joint>
    <joint type="revolute" name="front_left_wheel_joint"><child>front_left_wheel</child><parent>front_left_knuckle</parent><axis><xyz>0 0 1</xyz></axis></joint>
    <joint type="revolute" name="front_right_wheel_joint"><child>front_right_wheel</child><parent>front_right_knuckle</parent><axis><xyz>0 0 1</xyz></axis></joint>
    <joint type="revolute" name="rear_left_wheel_joint"><child>rear_left_wheel</child><parent>chassis</parent><axis><xyz>0 0 1</xyz></axis></joint>
    <joint type="revolute" name="rear_right_wheel_joint"><child>rear_right_wheel</child><parent>chassis</parent><axis><xyz>0 0 1</xyz></axis></joint>

    <plugin filename="libignition-gazebo-joint-position-controller-system.so" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>front_left_steer_joint</joint_name>
      <topic>/model/driftbot/joint/front_left_steer_joint/cmd_pos</topic>
    </plugin>
    <plugin filename="libignition-gazebo-joint-position-controller-system.so" name="ignition::gazebo::systems::JointPositionController">
      <joint_name>front_right_steer_joint</joint_name>
      <topic>/model/driftbot/joint/front_right_steer_joint/cmd_pos</topic>
    </plugin>
    <plugin filename="libignition-gazebo-joint-controller-system.so" name="ignition::gazebo::systems::JointController">
      <joint_name>rear_left_wheel_joint</joint_name>
      <topic>/model/driftbot/joint/rear_left_wheel_joint/cmd_vel</topic>
      <p_gain>10.0</p_gain>
    </plugin>
    <plugin filename="libignition-gazebo-joint-controller-system.so" name="ignition::gazebo::systems::JointController">
      <joint_name>rear_right_wheel_joint</joint_name>
      <topic>/model/driftbot/joint/rear_right_wheel_joint/cmd_vel</topic>
      <p_gain>10.0</p_gain>
    </plugin>
    <plugin filename="libignition-gazebo-odometry-publisher-system.so" name="ignition::gazebo::systems::OdometryPublisher">
      <odom_topic>/model/driftbot/odometry</odom_topic>
    </plugin>
  </model>
</sdf>